rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net: Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- GLOBAL HELPER FUNCTIONS ---
    
    // Validates document ID formatting to prevent resource poisoning
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    // Quick aliases for request payloads
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    // --- SCHEMA VALIDATION BLUEPRINTS ---
    
    // Validates the structure of the Survey Questions document
    function isValidSurveyQuestions(data) {
      return data.keys().hasAll(['questions', 'updatedAt']) 
        && data.keys().size() == 2 
        && data.questions is list 
        && data.questions.size() <= 100
        && data.updatedAt is string
        && data.updatedAt.size() <= 100;
    }

    // Validates the structure of the Webhook Config document
    function isValidWebhookConfig(data) {
      return data.keys().hasAll(['webhookUrl', 'updatedAt']) 
        && data.keys().size() == 2 
        && data.webhookUrl is string 
        && data.webhookUrl.size() <= 1024
        && data.updatedAt is string
        && data.updatedAt.size() <= 100;
    }

    // Validates the structure of the Survey Settings document
    function isValidSurveySettings(data) {
      return data.keys().hasAll(['allowAnonymous', 'updatedAt']) 
        && data.keys().size() == 2 
        && data.allowAnonymous is bool
        && data.updatedAt is string
        && data.updatedAt.size() <= 100;
    }

    // Validates the structure of a single survey response
    function isValidSurveyResponse(data) {
      return data.keys().hasAll(['userName', 'answers', 'timestamp']) 
        && data.keys().size() == 3 
        && data.userName is string 
        && data.userName.size() > 0 
        && data.userName.size() <= 100
        && data.answers is map 
        && data.timestamp is string
        && data.timestamp.size() <= 100;
    }

    // --- COLLECTION RULES ---

    // Rules for survey and application settings configuration
    match /config/{configId} {
      // Allow anyone to read the configurations to load the survey
      allow get: if isValidId(configId);
      
      // Block unmapped list queries
      allow list: if false;
      
      // Allow writing to configurations if the incoming payload matches the corresponding strict schema
      allow create, update: if isValidId(configId) && (
        (configId == 'survey_questions' && isValidSurveyQuestions(incoming())) ||
        (configId == 'webhook' && isValidWebhookConfig(incoming())) ||
        (configId == 'survey_settings' && isValidSurveySettings(incoming()))
      );
      
      // Prevent deleting core config documents
      allow delete: if false;
    }

    // Rules for user survey response submissions
    match /responses/{responseId} {
      // Allow getting and listing of responses (needed for admin statistics/dashboard)
      allow get, list: if isValidId(responseId);
      
      // Allow submitting responses as long as the format is correct
      allow create: if isValidId(responseId) && isValidSurveyResponse(incoming());
      
      // Terminally lock state: Survey responses are write-once (immutable) to prevent tampering
      allow update: if false;
      
      // Allow deleting responses (clean-up operation from admin panel)
      allow delete: if isValidId(responseId);
    }
  }
}
